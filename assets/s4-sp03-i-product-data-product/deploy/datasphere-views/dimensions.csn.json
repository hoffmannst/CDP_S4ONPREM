        "ValuationClass": { "type": "cds.String", "length": 4, "@EndUserText.label": "Valuation Class" },
        "PriceControlIndicator": { "type": "cds.String", "length": 1, "@EndUserText.label": "Price Control Indicator" },
        "StandardPrice": { "type": "cds.Decimal", "precision": 13, "scale": 2, "@EndUserText.label": "Standard Price", "@Semantics.amount.currencyCode": "Currency" },
        "MovingAveragePrice": { "type": "cds.Decimal", "precision": 13, "scale": 2, "@EndUserText.label": "Moving Average Price", "@Semantics.amount.currencyCode": "Currency" },
        "FuturePrice": { "type": "cds.Decimal", "precision": 13, "scale": 2, "@EndUserText.label": "Future Price", "@Semantics.amount.currencyCode": "Currency" },
        "TotalStockValue": { "type": "cds.Decimal", "precision": 13, "scale": 2, "@EndUserText.label": "Total Stock Value", "@Semantics.amount.currencyCode": "Currency" },
        "Currency": { "type": "cds.String", "length": 5, "@EndUserText.label": "Currency", "@Semantics.currencyCode": true },
