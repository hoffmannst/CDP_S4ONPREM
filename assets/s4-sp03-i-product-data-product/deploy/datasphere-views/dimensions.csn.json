        "Product": { "key": true, "type": "cds.String", "length": 40, "@EndUserText.label": "Product", "@ObjectModel.foreignKey.association": "_ProductValuation" },
        "ValuationArea": { "key": true, "type": "cds.String", "length": 4, "@EndUserText.label": "Valuation Area" },
