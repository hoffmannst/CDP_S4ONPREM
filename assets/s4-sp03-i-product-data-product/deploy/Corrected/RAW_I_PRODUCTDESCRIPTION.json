      "@ObjectModel.modelingPattern": {
        "#": "DATA_STRUCTURE"
      },
      "@ObjectModel.supportedCapabilities": [
        {
          "#": "DATA_STRUCTURE"
        }
      ],
      "@DataWarehouse.persistence.hdlf.tableFormat": {
        "#": "DELTA_LAKE"
      },
      "@DataWarehouse.delta.changeDataCapture": {
        "#": "DELTA"
      },
      "elements": {
        "MANDT": {
          "key": true,
          "type": "cds.String",
          "length": 3,
          "@EndUserText.label": "Client",
          "@EndUserText.quickInfo": "SAP Client (Mandant)"
        },
        "MATNR": {
          "key": true,
          "type": "cds.String",
          "length": 40,
          "@EndUserText.label": "Material Number",
          "@EndUserText.quickInfo": "Unique identifier of the product / material in S/4HANA",
          "@Semantics.systemDate.createdAt": false
        },
        "SPRAS": {
          "key": true,
          "type": "cds.String",
          "length": 2,
          "@EndUserText.label": "Language Key",
          "@EndUserText.quickInfo": "ISO language key for the description (e.g. EN, DE)",
          "@Semantics.language": true
        },
        "MAKTX": {
          "type": "cds.String",
          "length": 40,
          "@EndUserText.label": "Product Description",
          "@EndUserText.quickInfo": "Short description of the product in the given language",
          "key": false
        },
        "MAKTG": {
          "type": "cds.String",
          "length": 40,
          "@EndUserText.label": "Product Description (Uppercase)",
          "@EndUserText.quickInfo": "Uppercase version of the product description used for search",
          "key": false
        },
        "EXTRACTION_DATE": {
          "type": "cds.Date",
          "@EndUserText.label": "Extraction Date",
          "@EndUserText.quickInfo": "Date on which the record was extracted from S/4HANA into HDLFS",
          "key": false
        }
      },
      "@DataWarehouse.persistence.hdlf.enableDeletionVectors": false,
      "@DataWarehouse.delta": {
        "type": {
          "#": "ACTIVE"
        },
        "deltaFromEntities": [
          "RAW_I_PRODUCTDESCRIPTION_Delta"
        ]
      },
      "_meta": {
        "dependencies": {
          "folderAssignment": null
        }
      }
    },
