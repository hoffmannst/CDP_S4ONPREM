          "@EndUserText.quickInfo": "SAP Client (Mandant)"
        },
        "MATNR": {
          "key": true,
          "type": "cds.String",
          "length": 40,
          "@EndUserText.label": "Material Number",
          "@EndUserText.quickInfo": "Unique identifier of the product / material in S/4HANA",
