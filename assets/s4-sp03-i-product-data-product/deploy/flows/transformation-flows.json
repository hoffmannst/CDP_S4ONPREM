        { "source": "MTVFP", "target": "AvailabilityCheckType" },
        { "source": "DISGR", "target": "MRPGroup" },
        { "source": "DISMM", "target": "MRPType" },
        { "source": "DISPO", "target": "MRPResponsible" },
        { "source": "MHDLP", "target": "MinimumRemainingShelfLife" },
        { "source": "IPRKZ", "target": "TotalShelfLife" },
        { "source": "EXTRACTION_DATE", "target": "EXTRACTION_DATE" }
      ]
    },
    {
