{
  "version": "1.0.0",
  "description": "Datasphere Transformation Flow definitions — 22 flows, one per entity. Each transforms RAW → REF in HDLFS space. Deploy via Datasphere CLI: datasphere transformation-flows import --file transformation-flows.json --space PM_OBJSTORE",
  "space": "PM_OBJSTORE",
  "transformationFlows": [
    {
      "id": "TF-01",
      "name": "TF_RAW_TO_REF_PRODUCT",
      "description": "Transform RAW_I_PRODUCT → REF_PRODUCT. Renames ABAP fields to semantic names. Casts LVORM CHAR(1) to BOOLEAN. Adds EXTRACTION_DATE partition column.",
      "source": { "object": "RAW_I_PRODUCT", "space": "PM_OBJSTORE" },
      "target": { "object": "REF_PRODUCT", "space": "PM_OBJSTORE", "loadType": "UPSERT", "keyFields": ["Client","Product"] },
      "mappings": [
        { "source": "MANDT", "target": "Client" },
        { "source": "MATNR", "target": "Product" },
        { "source": "MTART", "target": "ProductType" },
        { "source": "MATKL", "target": "ProductGroup" },
        { "source": "MEINS", "target": "BaseUnit" },
        { "source": "GEWEI", "target": "WeightUnit" },
        { "source": "BRGEW", "target": "GrossWeight" },
        { "source": "NTGEW", "target": "NetWeight" },
        { "source": "VOLEH", "target": "VolumeUnit" },
        { "source": "VOLUM", "target": "Volume" },
        { "source": "SPART", "target": "Division" },
        { "source": "PRDHA", "target": "ProductHierarchy" },
        { "source": "GROES", "target": "SizeOrDimensionText" },
        { "source": "BRSCH", "target": "IndustrySector" },
        { "source": "MSTAE", "target": "CrossPlantStatus" },
        { "source": "MSTAV", "target": "CrossPlantStatusValidityDate" },
        { "source": "ERSDA", "target": "CreationDate" },
        { "source": "LAEDA", "target": "LastChangeDate" },
        { "source": "LVORM", "target": "IsMarkedForDeletion", "transform": "CASE WHEN LVORM = 'X' THEN TRUE ELSE FALSE END" },
        { "source": "EXTRACTION_DATE", "target": "EXTRACTION_DATE" }
      ],
      "lookups": [
        {
          "description": "Resolve MTART → ProductTypeText via T134T",
          "lookupTable": "T134T",
          "joinCondition": "RAW_I_PRODUCT.MTART = T134T.MTART AND RAW_I_PRODUCT.MANDT = T134T.MANDT AND T134T.SPRAS = 'E'",
          "sourceField": "T134T.MTBEZ",
          "targetField": "ProductTypeText"
        },
        {
          "description": "Resolve MATKL → ProductGroupText via T023T",
          "lookupTable": "T023T",
          "joinCondition": "RAW_I_PRODUCT.MATKL = T023T.MATKL AND RAW_I_PRODUCT.MANDT = T023T.MANDT AND T023T.SPRAS = 'E'",
          "sourceField": "T023T.WGBEZ",
          "targetField": "ProductGroupText"
        }
      ]
    },
    {
      "id": "TF-02",
      "name": "TF_RAW_TO_REF_PRODUCTTEXT",
      "description": "Transform RAW_I_PRODUCTTEXT → REF_PRODUCTTEXT. Renames ABAP fields to semantic names. Preserves all language records.",
      "source": { "object": "RAW_I_PRODUCTTEXT", "space": "PM_OBJSTORE" },
      "target": { "object": "REF_PRODUCTTEXT", "space": "PM_OBJSTORE", "loadType": "UPSERT", "keyFields": ["Client","Product","Language"] },
      "mappings": [
        { "source": "MANDT", "target": "Client" },
        { "source": "MATNR", "target": "Product" },
        { "source": "SPRAS", "target": "Language" },
        { "source": "MAKTX", "target": "ProductDescription" },
        { "source": "MAKTG", "target": "ProductDescriptionUpperCase" },
        { "source": "EXTRACTION_DATE", "target": "EXTRACTION_DATE" }
      ]
    },
    {
      "id": "TF-03",
      "name": "TF_RAW_TO_REF_PRODUCTUOM",
      "description": "Transform RAW_I_PRODUCTUOM → REF_PRODUCTUOM. Maps MEINH→AlternativeUnit, UMREZ/UMREN→numerator/denominator, EAN11→GTIN.",
      "source": { "object": "RAW_I_PRODUCTUOM", "space": "PM_OBJSTORE" },
      "target": { "object": "REF_PRODUCTUOM", "space": "PM_OBJSTORE", "loadType": "UPSERT", "keyFields": ["Client","Product","AlternativeUnit"] },
      "mappings": [
        { "source": "MANDT", "target": "Client" },
        { "source": "MATNR", "target": "Product" },
        { "source": "MEINH", "target": "AlternativeUnit" },
        { "source": "UMREZ", "target": "QuantityNumerator" },
        { "source": "UMREN", "target": "QuantityDenominator" },
        { "source": "EAN11", "target": "GlobalTradeItemNumber" },
        { "source": "NUMTP", "target": "GlobalTradeItemNumberCategory" },
        { "source": "EXTRACTION_DATE", "target": "EXTRACTION_DATE" }
      ]
    },
    {
      "id": "TF-04",
      "name": "TF_RAW_TO_REF_PRODUCTPLANT",
      "description": "Transform RAW_I_PRODUCTPLANT → REF_PRODUCTPLANT. Renames plant fields to semantic names.",
      "source": { "object": "RAW_I_PRODUCTPLANT", "space": "PM_OBJSTORE" },
